# ==================== Environment ====================
NODE_ENV=development

# ==================== API ====================
PORT=3001
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# ==================== Database ====================
DATABASE_URL=postgresql://captagov:captagov_dev@localhost:5432/captagov?schema=public
POSTGRES_USER=captagov
POSTGRES_PASSWORD=captagov_dev
POSTGRES_DB=captagov
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=captagov_redis

# ==================== RabbitMQ ====================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=captagov
RABBITMQ_PASS=captagov_rabbit
RABBITMQ_PASSWORD=captagov_rabbit

# ==================== JWT ====================
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=3600
JWT_REFRESH_SECRET=change-this-to-a-random-refresh-secret
JWT_REFRESH_EXPIRES_IN=604800

# ==================== SIOP ====================
SIOP_API_URL=https://api.siop.gov.br/graphql
SIAP_API_KEY=

# ==================== Email (SMTP) ====================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ==================== Frontend ====================
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
WEB_PORT=3000
